{
  "name": "vag-public-demo-release",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "desktop/main.mjs",
  "productName": "VAG Bounded Demo",
  "description": "VAG Bounded Demo — Local bounded gateway verification demonstration. Not production, not a sandbox, not system-wide enforcement.",
  "workspaces": [
    "demo-gateway",
    "demo-ui"
  ],
  "scripts": {
    "gateway": "node demo-gateway/src/server.mjs",
    "dev": "npm run --workspace=demo-ui dev",
    "build": "npm run --workspace=demo-ui build",
    "probe:public": "node tools/public_demo_probe.mjs",
    "smoke": "node tools/gateway_smoke.mjs",
    "test": "node --test test/*.test.mjs",
    "desktop:start": "npm run build && electron-forge start",
    "desktop:package": "npm run build && electron-forge package",
    "desktop:make": "npm run build && electron-forge make",
    "desktop:smoke:packaged": "electron desktop/main.mjs --smoke-test"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "electron": "^43.2.0"
  }
}
